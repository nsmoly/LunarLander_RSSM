{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Collect Data",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/collect_dataset.py",
            "args": [
                "--dataset", "lunarlander_dataset.npz",
                "--seed", "12345"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Replay dataset",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/replay_dataset.py",
            "args": [
                "--dataset", "lunarlander_dataset.npz",
                "--episodes", "200",
                "--seed", "12345",
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Train World Model",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/train_models.py",
            "args": [
                "--phase", "world_model",
                "--config", "config.yaml",
                "--train_dataset", "lunarlander_train_dataset.npz",
                "--val_dataset", "lunarlander_val_dataset.npz",
                "--seed", "12345"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Test World Model",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/test_worldmodel.py",
            "args": [
                "--dataset", "lunarlander_val_dataset.npz",
                "--config", "config.yaml",
                "--checkpoint", "world_model.pt",
                "--mode", "teacher",
                "--max_episodes", "20",
                "--seed", "12345",
                "--plot_dir", "plots",
                "--animate",
                "--constant_action", "0"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Train Actor-Critic",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/train_models.py",
            "args": [
                "--phase", "actor_critic",
                "--config", "config.yaml",
                "--seed", "12345"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Test Policy",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/test_policy.py",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "WorldModel Sim (pygame)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/worldmodel_sim_pygame.py",
            "args": [
                "--config", "config.yaml",
                "--world_model", "world_model.pt",
                "--val_dataset", "lunarlander_val_dataset.npz",
                "--seed", "12345",
                "--warmup_steps", "15",
                "--fps", "30",
                "--max_episode_steps", "500",
                "--print_every", "10",
                "--width", "960",
                "--height", "640"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "WM MPC Policy (CEM)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/wm_mpc_policy.py",
            "args": [
                "--config", "config.yaml",
                "--world_model", "world_model.pt",
                "--episodes", "20",
                "--seed", "12345",
                "--render",
                "--horizon", "15",
                "--population", "256",
                "--elites", "32",
                "--cem_iters", "4"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}